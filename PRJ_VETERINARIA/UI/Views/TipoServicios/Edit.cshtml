@model PRJ_VETERINARIA.DataAccessLayer.ViewModels.TipoServicios.TipoServicioViewModel
@{
    ViewData["Title"] = "Editar Tipo de Servicio";
}

<div class="vet-card">
    <div class="vet-card-header">
        <h4 class="mb-0 d-flex align-items-center">
            <i class="bi bi-pencil me-2 text-accent"></i> Editar Tipo de Servicio
        </h4>
    </div>
    <div class="vet-card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @Html.HiddenFor(model => model.IdTipoServicio)

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DuracionEstimadaMin" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="DuracionEstimadaMin" type="number" class="form-control" min="1" max="480" />
                        <span class="input-group-text">min</span>
                    </div>
                    <span asp-validation-for="DuracionEstimadaMin" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="EsMedico" class="form-check-input" type="checkbox" />
                        <label asp-for="EsMedico" class="form-check-label"></label>
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="Activo" class="form-check-input" type="checkbox" />
                        <label asp-for="Activo" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                    <i class="bi bi-check-circle"></i> Guardar cambios
                </button>
                <a asp-action="Index" class="btn btn-light">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}