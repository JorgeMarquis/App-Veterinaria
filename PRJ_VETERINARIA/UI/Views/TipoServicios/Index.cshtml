@model IEnumerable<PRJ_VETERINARIA.DataAccessLayer.ViewModels.TipoServicios.TipoServicioViewModel>
@{
    ViewData["Title"] = "Tipos de Servicios";
}

<div class="vet-card">
    <div class="vet-card-header d-flex justify-content-between align-items-center">
        <h1 class="h4 mb-0 d-flex align-items-center">
            <i class="bi bi-tags-fill me-2 text-accent"></i> Tipos de Servicios
        </h1>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-circle"></i> Nuevo tipo
        </a>
    </div>

    <div class="vet-card-body">
        <div class="input-group mb-3">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" id="searchTipo" class="form-control" 
                   placeholder="Buscar por nombre..." onkeyup="filterTable()">
        </div>

        <table class="vet-table table-hover" id="tipoTable">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>¿Es médico?</th>
                    <th>Duración estimada</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Nombre</strong></td>
                        <td>
                            @if (item.EsMedico)
                            {
                                <span class="badge bg-primary"><i class="bi bi-shield-check"></i> Médico</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No médico</span>
                            }
                        </td>
                        <td>
                            @if (item.DuracionEstimadaMin.HasValue)
                            {
                                @item.DuracionEstimadaMin <small class="text-muted">min</small>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (item.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.IdTipoServicio" 
                               class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="#" class="btn btn-sm btn-outline-danger delete-btn" 
                               data-url="@Url.Action("Delete", "TipoServicios", new { id = item.IdTipoServicio })">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            const input = document.getElementById("searchTipo").value.toLowerCase();
            const rows = document.querySelectorAll("#tipoTable tbody tr");
            rows.forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(input) ? "" : "none";
            });
        }
    </script>
}