@model IEnumerable<PRJ_VETERINARIA.DataAccessLayer.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Usuarios</h2>
    <a asp-action="Create" class="btn btn-primary">Nuevo Usuario</a>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Nombre</th>
                        <th>Rol</th>
                        <th>Especialidad</th>
                        <th>Teléfono</th>
                        <th>Último Acceso</th>
                        <th>Activo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Email</td>
                            <td>@item.NombreCompleto</td>
                            <td>@item.Rol</td>
                            <td>@item.Especialidad</td>
                            <td>@item.Telefono</td>
                            <td>@(item.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">No</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-warning">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-info text-white">Detalle</a>
                                <a asp-action="Delete" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
