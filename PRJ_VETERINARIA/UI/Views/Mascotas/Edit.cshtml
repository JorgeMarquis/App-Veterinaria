@model PRJ_VETERINARIA.DataAccessLayer.ViewModels.Mascotas.MascotaViewModel

@{
    ViewData["Title"] = "Editar Mascota";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Editar Mascota
                    </h4>
                </div>

                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validationSummary"></div>
                        <input type="hidden" asp-for="IdMascota" />

                        <div class="mb-3">
                            <label asp-for="IdCliente" class="form-label fw-bold">
                                <i class="bi bi-person-fill"></i> Cliente
                            </label>
                            <select asp-for="IdCliente" class="form-select" asp-items="Model.ClientesDisponibles" required></select>
                            <span asp-validation-for="IdCliente" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold">
                                <i class="bi bi-paw-fill"></i> Nombre
                            </label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre de la mascota" required />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="IdEspecie" class="form-label fw-bold">
                                        <i class="bi bi-tags-fill"></i> Especie
                                    </label>
                                    <select asp-for="IdEspecie" class="form-select" asp-items="Model.EspeciesDisponibles" required></select>
                                    <span asp-validation-for="IdEspecie" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="IdRaza" class="form-label fw-bold">
                                        <i class="bi bi-bookmark-fill"></i> Raza
                                    </label>
                                    <select asp-for="IdRaza" class="form-select" asp-items="Model.RazasDisponibles"></select>
                                    <span asp-validation-for="IdRaza" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="FechaNacimiento" class="form-label fw-bold">
                                        <i class="bi bi-calendar-event"></i> Fecha de Nacimiento
                                    </label>
                                    <input asp-for="FechaNacimiento" type="date" class="form-control" />
                                    <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Sexo" class="form-label fw-bold">
                                        <i class="bi bi-venus-mars"></i> Sexo
                                    </label>
                                    <select asp-for="Sexo" class="form-select" required>
                                        <option value="">Seleccione</option>
                                        <option value="M">Macho</option>
                                        <option value="H">Hembra</option>
                                    </select>
                                    <span asp-validation-for="Sexo" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ColorPelaje" class="form-label fw-bold">
                                        <i class="bi bi-palette-fill"></i> Color del Pelaje
                                    </label>
                                    <input asp-for="ColorPelaje" class="form-control" placeholder="Ej. Negro, Blanco, Café" />
                                    <span asp-validation-for="ColorPelaje" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="MicrochipId" class="form-label fw-bold">
                                        <i class="bi bi-barcode"></i> Microchip ID
                                    </label>
                                    <input asp-for="MicrochipId" class="form-control" placeholder="Código del microchip" />
                                    <span asp-validation-for="MicrochipId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FotoUrl" class="form-label fw-bold">
                                <i class="bi bi-image"></i> URL de Foto
                            </label>
                            <input asp-for="FotoUrl" type="url" class="form-control" placeholder="https://ejemplo.com/foto.jpg" />
                            <span asp-validation-for="FotoUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FechaFallecimiento" class="form-label fw-bold">
                                <i class="bi bi-calendar-x"></i> Fecha de Fallecimiento
                            </label>
                            <input asp-for="FechaFallecimiento" type="date" class="form-control" />
                            <span asp-validation-for="FechaFallecimiento" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input class="form-check-input" type="checkbox" asp-for="Activo" id="activoCheck" />
                            <label class="form-check-label fw-bold" for="activoCheck">
                                <i class="bi bi-check-circle"></i> Mascota Activa
                            </label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Guardar Cambios
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Volver a la Lista
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
