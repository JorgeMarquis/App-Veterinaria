@model PRJ_VETERINARIA.DataAccessLayer.Models.Mascota

@{
    ViewData["Title"] = "Eliminar Mascota";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Eliminar Mascota
                    </h4>
                </div>

                <div class="card-body">
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-exclamation-circle"></i>
                        <strong> ¿Está seguro?</strong> Esta acción eliminará permanentemente el registro de la mascota.
                    </div>

                    <div class="bg-light p-3 rounded mb-4">
                        <h5 class="mb-3">
                            <i class="bi bi-paw-fill"></i> @Model?.Nombre
                        </h5>

                        <div class="row">
                            <div class="col-md-6">
                                <p class="text-muted small mb-1">Cliente</p>
                                <p class="fw-bold">@Model?.IdClienteNavigation?.NombreCompleto</p>
                            </div>
                            <div class="col-md-6">
                                <p class="text-muted small mb-1">Especie / Raza</p>
                                <p class="fw-bold">@Model?.IdEspecieNavigation?.Nombre / @Model?.IdRazaNavigation?.Nombre</p>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <p class="text-muted small mb-1">Sexo</p>
                                <p class="fw-bold">@Model?.Sexo</p>
                            </div>
                            <div class="col-md-6">
                                <p class="text-muted small mb-1">Fecha de Nacimiento</p>
                                <p class="fw-bold">@Model?.FechaNacimiento?.ToString("dd/MM/yyyy")</p>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="IdMascota" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Eliminar Definitivamente
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
