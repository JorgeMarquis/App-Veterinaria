@model IEnumerable<PRJ_VETERINARIA.DataAccessLayer.Models.Mascota>

@{
    ViewData["Title"] = "Lista de Mascotas";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2>
                <i class="bi bi-paw-fill"></i> Mascotas Registradas
            </h2>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Registrar Nueva Mascota
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th><i class="bi bi-paw-fill"></i> Nombre</th>
                        <th><i class="bi bi-person-fill"></i> Cliente</th>
                        <th><i class="bi bi-tags-fill"></i> Especie</th>
                        <th><i class="bi bi-bookmark-fill"></i> Raza</th>
                        <th><i class="bi bi-venus-mars"></i> Sexo</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mascota in Model)
                    {
                        <tr>
                            <td class="fw-bold">@mascota.Nombre</td>
                            <td>@mascota.IdClienteNavigation?.NombreCompleto</td>
                            <td>@mascota.IdEspecieNavigation?.Nombre</td>
                            <td>@mascota.IdRazaNavigation?.Nombre</td>
                            <td>
                                @if (mascota.Sexo == "M")
                                {
                                    <span class="badge bg-info">Macho</span>
                                }
                                else if (mascota.Sexo == "H")
                                {
                                    <span class="badge bg-warning">Hembra</span>
                                }
                                else
                                {
                                    <span>@mascota.Sexo</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@mascota.IdMascota" class="btn btn-sm btn-info" title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@mascota.IdMascota" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@mascota.IdMascota" class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> No hay mascotas registradas aún.
        </div>
    }
</div>
