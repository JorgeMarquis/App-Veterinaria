@model PRJ_VETERINARIA.DataAccessLayer.Models.Atencion

@{
    ViewData["Title"] = "Eliminar Atención";
}

<div class="container mt-4">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Eliminar Atención</h2>
            <span class="text-muted">Confirmar eliminación</span>
        </div>
    </div>

    <!-- Alerta de confirmación -->
    <div class="alert alert-warning d-flex align-items-start" role="alert">
        <i class="bi bi-exclamation-triangle me-3 fs-5"></i>
        <div>
            <h5 class="alert-heading">¿Está seguro?</h5>
            <p class="mb-0">Esta acción eliminará permanentemente la atención registrada. Este cambio no se puede deshacer.</p>
        </div>
    </div>

    <!-- Card con detalles -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light border-bottom">
            <h5 class="mb-0">Detalles de la Atención</h5>
        </div>
        <div class="card-body">
            <!-- Información General -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Mascota</h6>
                    <p class="fw-semibold">@(Model.IdMascotaNavigation == null ? "-" : Model.IdMascotaNavigation.IdMascota.ToString())</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Veterinario</h6>
                    <p class="fw-semibold">@(Model.IdVeterinarioNavigation == null ? "-" : Model.IdVeterinarioNavigation.IdUsuario.ToString())</p>
                </div>
            </div>

            <hr class="my-3" />

            <!-- Fechas y Tipo -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Fecha y Hora Inicio</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.FechaHoraInicio)</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Fecha y Hora Fin</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.FechaHoraFin)</p>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Tipo de Atención</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.TipoAtencion)</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Estado</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.Estado)</p>
                </div>
            </div>

            <hr class="my-3" />

            <!-- Motivo y Síntomas -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Motivo de Consulta</h6>
                    <p>@(string.IsNullOrEmpty(Model.MotivoConsulta) ? "-" : Model.MotivoConsulta)</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Síntomas</h6>
                    <p>@(string.IsNullOrEmpty(Model.Sintomas) ? "-" : Model.Sintomas)</p>
                </div>
            </div>

            <!-- Examen Físico y Diagnóstico -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Examen Físico</h6>
                    <p>@(string.IsNullOrEmpty(Model.ExamenFisico) ? "-" : Model.ExamenFisico)</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Diagnóstico</h6>
                    <p>@(string.IsNullOrEmpty(Model.Diagnostico) ? "-" : Model.Diagnostico)</p>
                </div>
            </div>

            <!-- Tratamiento y Recomendaciones -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Tratamiento</h6>
                    <p>@(string.IsNullOrEmpty(Model.Tratamiento) ? "-" : Model.Tratamiento)</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted small mb-2">Recomendaciones</h6>
                    <p>@(string.IsNullOrEmpty(Model.Recomendaciones) ? "-" : Model.Recomendaciones)</p>
                </div>
            </div>

            <hr class="my-3" />

            <!-- Vitales -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Peso (kg)</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.PesoAtencion)</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Temperatura (°C)</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.Temperatura)</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Frecuencia Cardíaca (bpm)</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.FrecuenciaCardiaca)</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Frecuencia Respiratoria (rpm)</h6>
                    <p class="fw-semibold">@Html.DisplayFor(model => model.FrecuenciaRespiratoria)</p>
                </div>
            </div>

            <!-- Observaciones -->
            <div class="row mb-4">
                <div class="col-12">
                    <h6 class="text-muted small mb-2">Observaciones</h6>
                    <p>@(string.IsNullOrEmpty(Model.Observaciones) ? "-" : Model.Observaciones)</p>
                </div>
            </div>

            <hr class="my-3" />

            <!-- Auditoría -->
            <div class="row mb-3">
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Creado</h6>
                    <p class="small">@Html.DisplayFor(model => model.CreatedAt)</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Por</h6>
                    <p class="small">@Model.CreatedBy</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Actualizado</h6>
                    <p class="small">@Html.DisplayFor(model => model.UpdatedAt)</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-muted small mb-2">Por</h6>
                    <p class="small">@Model.UpdatedBy</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones -->
    <div class="d-flex gap-2">
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" asp-for="IdAtencion" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i> Eliminar Atención
            </button>
        </form>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Cancelar
        </a>
    </div>
</div>
