@model IEnumerable<PRJ_VETERINARIA.DataAccessLayer.Models.Raza>

@{
    ViewData["Title"] = "Razas";
}

<div class="container">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Razas Registradas</h2>
            <span class="text-muted">@Model.Count() razas registradas</span>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Nueva Raza
        </a>
    </div>

    @if (!Model.Any())
    {
        <!-- Estado vacío -->
        <div class="card border-0 shadow-sm text-center p-5">
            <div class="mb-3 fs-1 text-muted">
                <i class="bi bi-info-circle"></i>
            </div>
            <h5 class="mb-2">No hay razas registradas</h5>
            <p class="text-muted mb-3">
                Empieza agregando la primera raza al sistema.
            </p>
            <a asp-action="Create" class="btn btn-outline-primary">
                Registrar primera raza
            </a>
        </div>
    }
    else
    {
        <!-- Tabla -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Raza</th>
                            <th>Especie</th>
                            <th>Dimensión</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Nombre</td>

                                <td>
                                    <span class="text-muted">
                                        @item.IdEspecieNavigation.Nombre
                                    </span>
                                </td>

                                <td>@(item.Dimension ?? "-")</td>

                                <td class="text-center">
                                    @if (item.Activo)
                                    {
                                        <span class="badge rounded-pill bg-success">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.IdRaza"
                                           class="btn btn-sm btn-outline-warning me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <a asp-action="Details" asp-route-id="@item.IdRaza"
                                           class="btn btn-sm btn-outline-info me-1">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.IdRaza"
                                           class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    }

</div>
