@model PRJ_VETERINARIA.DataAccessLayer.ViewModels.Especies.EspecieViewModel

@{
    ViewData["Title"] = "Nueva Especie";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-4 col-md-6">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white py-2">
                    <h5 class="mb-0">🐾 Nueva Especie</h5>
                </div>

                <div class="card-body">

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger py-1 small"></div>

                        <div class="mb-2">
                            <label asp-for="Nombre" class="form-label fw-semibold small"></label>
                            <input asp-for="Nombre"
                                   class="form-control form-control-sm"
                                   placeholder="Ej: Canino, Felino" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-semibold small"></label>
                            <textarea asp-for="Descripcion"
                                      class="form-control form-control-sm"
                                      rows="3"
                                      placeholder="Descripción breve de la especie"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-sm">
                                💾 Guardar
                            </button>

                            <a asp-action="Index"
                                   class="btn btn-outline-secondary btn-sm">
                                ↩ Volver
                            </a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
