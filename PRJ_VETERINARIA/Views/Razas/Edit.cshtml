@model PRJ_VETERINARIA.ViewModels.Razas.RazaViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Raza</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdRaza" />
            <div class="form-group">
                <label asp-for="IdEspecie" class="form-label"></label>
                <select asp-for="IdEspecie"
                        asp-items="Model.EspeciesDisponibles"
                        class="form-select">
                    <option value="">-- Seleccione una especie --</option>
                </select>
                <span asp-validation-for="IdEspecie" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Dimension" class="control-label"></label>
                <input asp-for="Dimension" class="form-control" />
                <span asp-validation-for="Dimension" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
