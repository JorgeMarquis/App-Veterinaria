@model IEnumerable<PRJ_VETERINARIA.Models.Raza>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Razas</h1>
        <span class="text-muted">@Model.Count() razas registradas</span>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        + Nueva Raza
    </a>
</div>

@if (!Model.Any())
{
    <div>
        <p>No hay razas registradas</p>
        <a asp-action="Create">Registrar la primera raza</a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Raza</th>
                        <th>Especie</th>
                        <th>Dimension</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-medium">@item.Nombre</td>
                            <td>@item.IdEspecieNavigation.Nombre</td>
                            <td>@(item.Dimension ?? "-")</td>
                            <td class="text-center">
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.IdRaza">Edit</a> |
                                <a asp-action="Details" asp-route-id="@item.IdRaza">Details</a> |
                                <a asp-action="Delete" asp-route-id="@item.IdRaza">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

