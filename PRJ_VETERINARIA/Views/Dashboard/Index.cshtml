@model PRJ_VETERINARIA.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Dashboard</h2>
        <p class="text-muted mb-0">Bienvenido, @User.Identity?.Name</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h6 class="text-muted">Clientes</h6>
                <h2>@Model.TotalClientes</h2>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h6 class="text-muted">Mascotas</h6>
                <h2>@Model.TotalMascotas</h2>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h6 class="text-muted">Productos</h6>
                <h2>@Model.TotalProductos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h6 class="text-muted">Usuarios Activos</h6>
                <h2>@Model.TotalUsuariosActivos</h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="mb-3">Accesos rápidos</h5>
                <div class="d-grid gap-2">
                    <a asp-controller="Clientes" asp-action="Create" class="btn btn-outline-primary">Registrar Cliente</a>
                    <a asp-controller="Mascotas" asp-action="Create" class="btn btn-outline-primary">Registrar Mascota</a>
                    <a asp-controller="Productos" asp-action="Create" class="btn btn-outline-primary">Registrar Producto</a>
                    <a asp-controller="Vacunas" asp-action="Index" class="btn btn-outline-primary">Ver Vacunas</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="mb-3">Resumen del sistema</h5>
                <p><strong>Total de vacunas registradas:</strong> @Model.TotalVacunas</p>
                <p><strong>Rol actual:</strong> @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                <p class="text-muted mb-0">Sistema veterinario operativo.</p>
            </div>
        </div>
    </div>
</div>