@model PRJ_VETERINARIA.ViewModels.Usuarios.UsuarioViewModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<h2 class="mb-4">Editar Usuario</h2>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="IdUsuario" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="NombreCompleto" class="form-label"></label>
                    <input asp-for="NombreCompleto" class="form-control" />
                    <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Rol" class="form-label"></label>
                    <select asp-for="Rol" class="form-select"
                            asp-items="@(new SelectList(PRJ_VETERINARIA.ViewModels.Usuarios.UsuarioViewModel.RolesDisponibles))">
                        <option value="">-- Seleccione un rol --</option>
                    </select>
                    <span asp-validation-for="Rol" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label"></label>
                    <input asp-for="Telefono" class="form-control" />
                    <span asp-validation-for="Telefono" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Especialidad" class="form-label"></label>
                    <input asp-for="Especialidad" class="form-control" />
                    <span asp-validation-for="Especialidad" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="NumeroColegiado" class="form-label"></label>
                    <input asp-for="NumeroColegiado" class="form-control" />
                    <span asp-validation-for="NumeroColegiado" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input asp-for="Activo" class="form-check-input" />
                        <label asp-for="Activo" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Actualizar</button>
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}