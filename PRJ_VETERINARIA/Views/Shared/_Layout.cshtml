<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Veterinaria</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PRJ_VETERINARIA.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-heart-pulse-fill"></i> Veterinaria
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuNavbar">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Mascotas" asp-action="Index">Mascotas</a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Catálogos</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Especies" asp-action="Index">Especies</a></li>
                                    <li><a class="dropdown-item" asp-controller="Razas" asp-action="Index">Razas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Vacunas" asp-action="Index">Vacunas</a></li>
                                    <li><a class="dropdown-item" asp-controller="TipoServicios" asp-action="Index">Tipos de Servicio</a></li>
                                    <li><a class="dropdown-item" asp-controller="FormaPagos" asp-action="Index">Formas de Pago</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Inventario</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Productos" asp-action="Index">Productos</a></li>
                                    <li><a class="dropdown-item" asp-controller="CategoriaProductos" asp-action="Index">Categorías</a></li>
                                    <li><a class="dropdown-item" asp-controller="Proveedores" asp-action="Index">Proveedores</a></li>
                                </ul>
                            </li>

                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                                </li>
                            }
                        </ul>

                        <div class="d-flex align-items-center gap-3 text-white">
                            <div class="text-end">
                                <div class="small">Usuario: <strong>@User.Identity.Name</strong></div>
                                <div class="small">Rol: <strong>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</strong></div>
                            </div>

                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm">
                                    <i class="bi bi-box-arrow-right"></i> Salir
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted py-3 mt-4 bg-white">
        <div class="container">
            &copy; 2026 - Sistema Veterinaria
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>