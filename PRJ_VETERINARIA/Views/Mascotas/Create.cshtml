@model PRJ_VETERINARIA.ViewModels.Mascotas.MascotaViewModel

@{
    ViewData["Title"] = "Registrar Mascota";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">🐾 Registrar Mascota</h4>
                </div>

                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="IdCliente" class="form-label fw-bold"></label>
                            <select asp-for="IdCliente" class="form-select" asp-items="Model.ClientesDisponibles"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre de la mascota" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="IdEspecie" class="form-label fw-bold"></label>
                            <select asp-for="IdEspecie" class="form-select" asp-items="Model.EspeciesDisponibles"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="IdRaza" class="form-label fw-bold"></label>
                            <select asp-for="IdRaza" class="form-select" asp-items="Model.RazasDisponibles"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FechaNacimiento" class="form-label fw-bold"></label>
                            <input asp-for="FechaNacimiento" type="date" class="form-control" />
                            <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Sexo" class="form-label fw-bold"></label>
                            <input asp-for="Sexo" class="form-control" placeholder="Sexo: Ej. Macho(M), Hembra(H)"/>
                            <span asp-validation-for="Sexo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ColorPelaje" class="form-label fw-bold"></label>
                            <input asp-for="ColorPelaje" class="form-control" placeholder="Color del pelaje" />
                            <span asp-validation-for="ColorPelaje" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MicrochipId" class="form-label fw-bold"></label>
                            <input asp-for="MicrochipId" class="form-control" placeholder="Código de microchip (opcional)" />
                            <span asp-validation-for="MicrochipId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FotoUrl" class="form-label fw-bold"></label>
                            <input asp-for="FotoUrl" class="form-control" placeholder="URL de la foto" />
                            <span asp-validation-for="FotoUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FechaFallecimiento" class="form-label fw-bold"></label>
                            <input asp-for="FechaFallecimiento" type="date" class="form-control" />
                            <span asp-validation-for="FechaFallecimiento" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                💾 Guardar Mascota
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                ↩ Volver a la Lista
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}