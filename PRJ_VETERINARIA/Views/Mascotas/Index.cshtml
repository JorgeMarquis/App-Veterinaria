@model IEnumerable<PRJ_VETERINARIA.Models.Mascota>

@{
    ViewData["Title"] = "Lista de Mascotas";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>🐾 Mascotas Registradas</h2>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                ➕ Registrar Nueva Mascota
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Nombre</th>
                        <th>Cliente</th>
                        <th>Especie</th>
                        <th>Raza</th>
                        <th>Sexo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mascota in Model)
                    {
                        <tr>
                            <td>@mascota.Nombre</td>
                            <td>@mascota.IdClienteNavigation?.NombreCompleto</td>
                            <td>@mascota.IdEspecieNavigation?.Nombre</td>
                            <td>@mascota.IdRazaNavigation?.Nombre</td>
                            <td>@mascota.Sexo</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@mascota.IdMascota" class="btn btn-sm btn-info">👁 Ver</a>
                                <a asp-action="Edit" asp-route-id="@mascota.IdMascota" class="btn btn-sm btn-warning">✏ Editar</a>
                                <a asp-action="Delete" asp-route-id="@mascota.IdMascota" class="btn btn-sm btn-danger">🗑 Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No hay mascotas registradas.
        </div>
    }
</div>