@model PRJ_VETERINARIA.Models.Cliente

@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="container mt-4">

    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">
                <i class="bi bi-pencil-square"></i> Editar Cliente
            </h4>
        </div>

        <div class="card-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="IdCliente" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Datos personales -->
                <h6 class="text-warning mb-3">Datos Personales</h6>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="NombreCompleto" class="form-label"></label>
                        <input asp-for="NombreCompleto" class="form-control" />
                        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TipoIdentificacion" class="form-label"></label>
                        <select asp-for="TipoIdentificacion" class="form-select">
                            <option>DNI</option>
                            <option>RUC</option>
                            <option>Pasaporte</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="NumIdentificacion" class="form-label"></label>
                        <input asp-for="NumIdentificacion" class="form-control" />
                    </div>
                </div>

                <!-- Contacto -->
                <h6 class="text-warning mb-3">Contacto</h6>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TelefonoPrincipal" class="form-label"></label>
                        <input asp-for="TelefonoPrincipal" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TelefonoAlternativo" class="form-label"></label>
                        <input asp-for="TelefonoAlternativo" class="form-control" />
                    </div>
                </div>

                <!-- Dirección -->
                <h6 class="text-warning mb-3">Dirección</h6>

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label asp-for="Direccion" class="form-label"></label>
                        <input asp-for="Direccion" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Ciudad" class="form-label"></label>
                        <input asp-for="Ciudad" class="form-control" />
                    </div>
                </div>

                <!-- Emergencia -->
                <h6 class="text-warning mb-3">Emergencia</h6>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="ContactoEmergencia" class="form-label"></label>
                        <input asp-for="ContactoEmergencia" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TelefonoEmergencia" class="form-label"></label>
                        <input asp-for="TelefonoEmergencia" class="form-control" />
                    </div>
                </div>

                <!-- Observaciones -->
                <div class="mb-3">
                    <label asp-for="Observaciones" class="form-label"></label>
                    <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                </div>

                <!-- Estado -->
                <div class="form-check form-switch mb-4">
                    <input class="form-check-input" asp-for="Activo" />
                    <label class="form-check-label" asp-for="Activo">
                        Cliente activo
                    </label>
                </div>

                <!-- Botones -->
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>

                    <button type="submit" class="btn btn-warning text-dark">
                        <i class="bi bi-save"></i> Guardar Cambios
                    </button>
                </div>

            </form>
        </div>

        <!-- Auditoría -->
        <div class="card-footer text-muted small">
            Creado el: @Model.CreatedAt |
            Última actualización: @Model.UpdatedAt
        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}