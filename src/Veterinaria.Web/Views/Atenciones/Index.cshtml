@model IEnumerable<Veterinaria.Domain.Entities.Atencion>

@{
    ViewData["Title"] = "Atenciones";
}

<div class="page-header">
    <div>
        <h1>Atenciones</h1>
        <div class="page-sub">Historial de consultas y procedimientos</div>
    </div>
    <a asp-action="Create" class="btn-vet btn-primary-vet">
        <i class="bi bi-plus"></i> Nueva atención
    </a>
</div>

<!-- Filters -->
<div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center;">
    <input type="text" id="searchInput" class="form-control-vet"
           placeholder="Buscar..." style="max-width:280px;">
    <select id="filterEstado" class="form-control-vet" style="width:160px;">
        <option value="">Todos los estados</option>
        <option>Programada</option>
        <option>EnProceso</option>
        <option>Completada</option>
        <option>Cancelada</option>
    </select>
</div>

<div class="vet-card">
    <div class="vet-card-body" style="padding:0">
        <table class="vet-table" id="atencionesTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Mascota</th>
                    <th>Veterinario</th>
                    <th>Tipo</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th style="text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    var estadoClass = a.Estado switch
                    {
                        "Completada" => "badge-green",
                        "Cancelada" => "badge-red",
                        "EnProceso" => "badge-blue",
                        _ => "badge-yellow"
                    };
                    <tr data-estado="@a.Estado">
                        <td class="mono" style="font-size:12px;color:var(--vet-muted)">#@a.IdAtencion</td>
                        <td style="font-weight:500">@a.IdMascotaNavigation?.Nombre</td>
                        <td>@a.IdVeterinarioNavigation?.NombreCompleto</td>
                        <td>@a.TipoAtencion</td>
                        <td class="mono" style="font-size:12px">
                            @a.FechaHoraInicio.ToString("dd/MM/yy HH:mm")
                        </td>
                        <td><span class="badge-vet @estadoClass">@a.Estado</span></td>
                        <td style="text-align:right">
                            <div style="display:flex;gap:4px;justify-content:flex-end">
                                <a asp-action="Details" asp-route-id="@a.IdAtencion"
                                       class="btn-vet btn-ghost-vet btn-icon" title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@a.IdAtencion"
                                      method="post" id="del-at-@a.IdAtencion" style="display:none">
                                    @Html.AntiForgeryToken()
                                </form>
                                <button type="button"
                                        class="btn-vet btn-ghost-vet btn-icon"
                                        onclick="confirmDelete('del-at-@a.IdAtencion')"
                                        title="Eliminar"
                                        style="color:var(--vet-danger);border-color:transparent">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilters() {
            const q = document.getElementById('searchInput').value.toLowerCase();
            const estado = document.getElementById('filterEstado').value;
            document.querySelectorAll('#atencionesTable tbody tr').forEach(r => {
                const matchText = r.textContent.toLowerCase().includes(q);
                const matchEstado = !estado || r.dataset.estado === estado;
                r.style.display = (matchText && matchEstado) ? '' : 'none';
            });
        }
        document.getElementById('searchInput').addEventListener('input', applyFilters);
        document.getElementById('filterEstado').addEventListener('change', applyFilters);
    </script>
}
