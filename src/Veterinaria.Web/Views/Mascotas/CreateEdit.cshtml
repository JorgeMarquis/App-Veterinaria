@model Veterinaria.Web.ViewModels.Mascotas.MascotaViewModel
@{
    bool isCreate = Model.IdMascota == 0;
    ViewData["Title"] = isCreate ? "Registrar Mascota" : "Editar Mascota";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-5">
                <h4 class="fw-bold mb-4 text-dark">
                    <i class="bi @(Model.IdMascota == 0 ? "bi-plus-circle" : "bi-pencil-square") text-primary me-2"></i>
                    @ViewData["Title"]
                </h4>

                <form asp-action="@(Model.IdMascota == 0 ? "Create" : "Edit")" novalidate>
                    @if (!isCreate)
                    {
                        <input type="hidden" asp-for="IdMascota" />
                    }
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <div class="form-floating">
                                <select asp-for="IdCliente" class="form-select" asp-items="Model.ClientesDisponibles" id="IdCliente" required>
                                    <option value="">Seleccione un cliente...</option>
                                </select>
                                <label asp-for="IdCliente">Dueño / Cliente <span class="text-danger">*</span></label>
                                <span asp-validation-for="IdCliente" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Nombre" class="form-control" placeholder="Nombre" required />
                                <label asp-for="Nombre">Nombre de la Mascota<span class="text-danger">*</span></label>
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="Sexo" class="form-select" asp-items="MascotaViewModel.OpcionesSexo" required>
                                    <option value="">Seleccione...</option>
                                </select>
                                <label asp-for="Sexo">Sexo <span class="text-danger">*</span></label>
                                <span asp-validation-for="Sexo" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="IdEspecie" class="form-select" asp-items="Model.EspeciesDisponibles" id="IdEspecie" required>
                                    <option value="">Seleccione especie...</option>
                                </select>
                                <label asp-for="IdEspecie">Especie <span class="text-danger">*</span></label>
                                <span asp-validation-for="IdEspecie" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="IdRaza" class="form-select" id="IdRaza">
                                    <option value="">Seleccione una raza...</option>
                                </select>
                                <label asp-for="IdRaza">Raza (Opcional)</label>
                                <span asp-validation-for="IdRaza" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="FechaNacimiento" type="date" class="form-control" />
                                <label asp-for="FechaNacimiento">F. Nacimiento</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="ColorPelaje" class="form-control" placeholder="Pelaje" />
                                <label asp-for="ColorPelaje">Color Pelaje</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="MicrochipId" class="form-control" placeholder="Microchip" />
                                <label asp-for="MicrochipId">N° Microchip</label>
                                <span asp-validation-for="MicrochipId" class="text-danger small"></span>
                            </div>
                        </div>

                        @if (!isCreate)
                        {
                            <div class="col-md-12 mt-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="Activo" id="activoCheck" />
                                    <label class="form-check-label fw-bold" for="activoCheck">
                                        Mascota Activa en el Sistema
                                    </label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-5">
                        <a asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">
                            @(isCreate ? "Guardar Paciente" : "Actualizar Paciente")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Lógica en Cascada: Especie -> Raza
            // Fallback a array vacío para evitar errores de parseo si ViewBag es nulo
            const rawJson = '@Html.Raw(ViewBag.RazasJson ?? "[]")';
            const razasData = JSON.parse(rawJson);

            const ddlEspecie = document.getElementById('IdEspecie');
            const ddlRaza = document.getElementById('IdRaza');
            const razaSeleccionadaId = '@Model?.IdRaza' || '';

            function actualizarRazas() {
                const especieId = ddlEspecie.value;

                // Reiniciar Dropdown de Razas
                ddlRaza.innerHTML = '<option value="">Seleccione una raza...</option>';

                if (especieId) {
                    const razasFiltradas = razasData.filter(r => r.idEspecie == especieId);


                    razasFiltradas.forEach(r => {
                        const opt = document.createElement('option');
                        opt.value = r.idRaza;
                        opt.textContent = r.nombre;
                        // Si estamos en Edit, mantener la raza seleccionada
                        if (r.idRaza == razaSeleccionadaId) {
                            opt.selected = true;
                        }
                        ddlRaza.appendChild(opt);
                    });
                }
            }

            // Escuchar cambios
            ddlEspecie.addEventListener('change', actualizarRazas);

            // Ejecutar al inicio (Útil para la vista Edit)
            actualizarRazas();
        });
    </script>
}