@model IEnumerable<Veterinaria.Web.ViewModels.Clientes.ClienteViewModel>

@{
    ViewData["Title"] = "Clientes";
}

<div class="page-header">
    <div>
        <h1>Clientes</h1>
        <div class="page-sub">@Model.Count() registros encontrados</div>
    </div>
    <a asp-action="Create" class="btn-vet btn-primary-vet">
        <i class="bi bi-plus"></i> Nuevo cliente
    </a>
</div>

<!-- Search bar -->
<div style="margin-bottom:16px;">
    <input type="text" id="searchInput" class="form-control-vet"
           placeholder="Buscar por nombre, documento o ciudad..."
           style="max-width:380px;">
</div>

<div class="vet-card">
    <div class="vet-card-body" style="padding:0">
        <table class="vet-table" id="clientesTable">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Documento</th>
                    <th>Teléfono</th>
                    <th>Ciudad</th>
                    <th>Estado</th>
                    <th style="text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div style="font-weight:500">@item.NombreCompleto</div>
                            @if (!string.IsNullOrEmpty(item.Email))
                            {
                                <div style="font-size:12px;color:var(--vet-muted)">@item.Email</div>
                            }
                        </td>
                        <td>
                            <span class="mono" style="font-size:12px">@item.TipoIdentificacion</span>
                            <br><span class="mono" style="font-size:12px">@item.NumIdentificacion</span>
                        </td>
                        <td>
                            @item.TelefonoPrincipal
                            @if (!string.IsNullOrEmpty(item.TelefonoAlternativo))
                            {
                                <br>
                            
                                <span style="font-size:12px;color:var(--vet-muted)">@item.TelefonoAlternativo</span>
                            }
                        </td>
                        <td>@item.Ciudad</td>
                        <td>
                            @if (item.Activo)
                            {
                                <span class="badge-vet badge-green">Activo</span>
                            }
                            else
                            {
                                <span class="badge-vet badge-gray">Inactivo</span>
                            }
                        </td>
                        <td style="text-align:right">
                            <div style="display:flex;gap:4px;justify-content:flex-end">
                                <a asp-action="Details" asp-route-id="@item.IdCliente"
                                       class="btn-vet btn-ghost-vet btn-icon" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.IdCliente"
                                       class="btn-vet btn-ghost-vet btn-icon" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.IdCliente"
                                      method="post" id="del-cli-@item.IdCliente" style="display:none">
                                    @Html.AntiForgeryToken()
                                </form>
                                <button type="button"
                                        class="btn-vet btn-ghost-vet btn-icon"
                                        onclick="confirmDelete('del-cli-@item.IdCliente')"
                                        title="Eliminar"
                                        style="color:var(--vet-danger);border-color:transparent">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#clientesTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>
}
