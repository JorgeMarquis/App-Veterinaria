@model IEnumerable<Veterinaria.Domain.Entities.Venta>

@{
    ViewData["Title"] = "Ventas";
    var totalVentas = Model.Where(v => v.EstadoPago != "Anulado").Sum(v => v.Total);
}

<div class="page-header">
    <div>
        <h1>Ventas</h1>
        <div class="page-sub">
            @Model.Count() registros · Total: <strong class="mono">S/ @totalVentas.ToString("N2")</strong>
        </div>
    </div>
    <a asp-action="Create" class="btn-vet btn-primary-vet">
        <i class="bi bi-plus"></i> Nueva venta
    </a>
</div>

<div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
    <input type="text" id="searchInput" class="form-control-vet"
           placeholder="Buscar por cliente o comprobante..." style="max-width:300px;">
    <select id="filterEstado" class="form-control-vet" style="width:160px;">
        <option value="">Todos los estados</option>
        <option>Pagado</option>
        <option>Pendiente</option>
        <option>Parcial</option>
        <option>Anulado</option>
    </select>
</div>

<div class="vet-card">
    <div class="vet-card-body" style="padding:0">
        <table class="vet-table" id="ventasTable">
            <thead>
                <tr>
                    <th>Comprobante</th>
                    <th>Cliente</th>
                    <th>Forma pago</th>
                    <th>Fecha</th>
                    <th style="text-align:right">Total</th>
                    <th>Estado</th>
                    <th style="text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    var eClass = v.EstadoPago switch
                    {
                        "Pagado" => "badge-green",
                        "Anulado" => "badge-red",
                        "Parcial" => "badge-yellow",
                        _ => "badge-gray"
                    };
                    <tr data-estado="@v.EstadoPago">
                        <td class="mono" style="font-size:12px">@v.NumeroComprobante</td>
                        <td style="font-weight:500">@v.IdClienteNavigation?.NombreCompleto</td>
                        <td>@v.IdFormaPagoNavigation?.Nombre</td>
                        <td class="mono" style="font-size:12px">@v.Fecha.ToString("dd/MM/yyyy")</td>
                        <td style="text-align:right" class="mono"><strong>S/ @v.Total.ToString("N2")</strong></td>
                        <td><span class="badge-vet @eClass">@v.EstadoPago</span></td>
                        <td style="text-align:right">
                            <div style="display:flex;gap:4px;justify-content:flex-end">
                                <a asp-action="Details" asp-route-id="@v.IdVenta"
                                       class="btn-vet btn-ghost-vet btn-icon" title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@v.IdVenta"
                                      method="post" id="del-ven-@v.IdVenta" style="display:none">
                                    @Html.AntiForgeryToken()
                                </form>
                                <button type="button"
                                        class="btn-vet btn-ghost-vet btn-icon"
                                        onclick="confirmDelete('del-ven-@v.IdVenta')"
                                        title="Eliminar"
                                        style="color:var(--vet-danger);border-color:transparent">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilter() {
            const q = document.getElementById('searchInput').value.toLowerCase();
            const e = document.getElementById('filterEstado').value;
            document.querySelectorAll('#ventasTable tbody tr').forEach(r => {
                r.style.display = (r.textContent.toLowerCase().includes(q) && (!e || r.dataset.estado === e)) ? '' : 'none';
            });
        }
        document.getElementById('searchInput').addEventListener('input', applyFilter);
        document.getElementById('filterEstado').addEventListener('change', applyFilter);
    </script>
}
