@model IEnumerable<Veterinaria.Domain.Entities.Especie>

@{
    ViewData["Title"] = "Especies";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-semibold text-dark">
            🐾 Gestión de Especies
        </h4>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            + Nueva especie
        </a>
    </div>

    @foreach (var item in Model)
    {
        <div class="card mb-2 shadow-sm">
            <div class="card-body py-2">

                <div class="row align-items-center">

                    <!-- Nombre y descripción -->
                    <div class="col-md-4">
                        <div class="fw-semibold">@item.Nombre</div>
                        <div class="text-muted small">
                            @item.Descripcion
                        </div>
                    </div>

                    <!-- Estado -->
                    <div class="col-md-2 text-center">
                        @if (item.Activo)
                        {
                            <span class="badge bg-success-subtle text-success">
                                Activo
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger">
                                Inactivo
                            </span>
                        }
                    </div>

                    <!-- Fechas -->
                    <div class="col-md-3 small text-muted">
                        <div>Creado: @item.FechaCreacion.ToString("dd/MM/yyyy")</div>
                        <div>
                            Modificado:
                            @(item.FechaModificacion != null
                                ? item.FechaModificacion.Value.ToString("dd/MM/yyyy")
                                : "-")
                        </div>
                    </div>

                    <!-- Acciones -->
                    <div class="col-md-3 text-end">
                        <a asp-action="Edit" asp-route-id="@item.IdEspecie"
                               class="btn btn-sm btn-outline-warning me-1">
                            Editar
                        </a>
                        <a asp-action="Details" asp-route-id="@item.IdEspecie"
                               class="btn btn-sm btn-outline-info me-1">
                            Ver
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.IdEspecie"
                               class="btn btn-sm btn-outline-danger">
                            Eliminar
                        </a>
                    </div>

                </div>
            </div>
        </div>
    }
</div>
