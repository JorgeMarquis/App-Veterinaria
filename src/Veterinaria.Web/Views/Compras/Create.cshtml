@model Veterinaria.Web.ViewModels.Compras.CompraViewModel

@{
    ViewData["Title"] = "Nueva Compra";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Nueva Compra</h1>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>
<hr />

<form asp-action="Create" id="formCompra">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    @* ── Cabecera ── *@
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-medium">Datos de la compra</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="IdProveedor" class="form-label"></label>
                    <select asp-for="IdProveedor"
                            asp-items="Model.ProveedoresDisponibles"
                            class="form-select">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="IdProveedor" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="IdFormaPago" class="form-label"></label>
                    <select asp-for="IdFormaPago"
                            asp-items="Model.FormasPagoDisponibles"
                            class="form-select">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="IdFormaPago" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="NumeroFactura" class="form-label"></label>
                    <input asp-for="NumeroFactura" class="form-control" />
                    <span asp-validation-for="NumeroFactura" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Fecha" class="form-label"></label>
                    <input asp-for="Fecha" class="form-control" type="date" />
                    <span asp-validation-for="Fecha" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="EstadoPago" class="form-label"></label>
                    <select asp-for="EstadoPago"
                            asp-items="Veterinaria.Web.ViewModels.Compras.CompraViewModel.EstadosPago"
                            class="form-select">
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Observaciones" class="form-label"></label>
                    <input asp-for="Observaciones" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    @* ── Detalle ── *@
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-medium">Detalle de productos</span>
            <button type="button" class="btn btn-sm btn-success" onclick="agregarFila()">
                + Agregar producto
            </button>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0" id="tablaDetalle">
                <thead class="table-light">
                    <tr>
                        <th>Producto</th>
                        <th>Lote</th>
                        <th>Fec. Vencimiento</th>
                        <th>Cantidad</th>
                        <th>Precio Unit.</th>
                        <th class="text-end">Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="cuerpoDetalle">
                    @* Las filas las genera JavaScript *@
                </tbody>
            </table>
        </div>
        <div class="card-footer text-end">
            <strong>Total: S/ <span id="totalGeneral">0.00</span></strong>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Guardar compra</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
    </div>
</form>

@* Guardamos los productos como JSON para los dropdowns dinámicos *@
<script id="productosData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.ProductosDisponibles.Select(p => new { value = p.Value, text = p.Text })
        ))
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const productos = JSON.parse(document.getElementById('productosData').textContent);
        let indiceFila = 0;

        // Construye el HTML de una fila del detalle
        function construirFila(indice) {
            // Opciones del dropdown de productos
            const opciones = productos.map(p =>
                `<option value="${p.value}">${p.text}</option>`
            ).join('');

            return `
            <tr id="fila-${indice}">
                <td>
                    <select name="Detalles[${indice}].IdProducto"
                            class="form-select form-select-sm">
                        <option value="">-- Seleccione --</option>
                        ${opciones}
                    </select>
                </td>
                <td>
                    <input name="Detalles[${indice}].Lote"
                           class="form-control form-control-sm"
                           placeholder="Ej: LOT-001" />
                </td>
                <td>
                    <input name="Detalles[${indice}].FechaVencimiento"
                           type="date"
                           class="form-control form-control-sm" />
                </td>
                <td>
                    <input name="Detalles[${indice}].Cantidad"
                           type="number" step="0.01" min="0.01"
                           class="form-control form-control-sm campo-calculo"
                           data-indice="${indice}"
                           oninput="calcularSubtotal(${indice})"
                           value="1" />
                </td>
                <td>
                    <input name="Detalles[${indice}].PrecioUnitario"
                           type="number" step="0.01" min="0.01"
                           class="form-control form-control-sm campo-calculo"
                           data-indice="${indice}"
                           oninput="calcularSubtotal(${indice})"
                           value="0" />
                </td>
                <td class="text-end align-middle">
                    <span id="subtotal-${indice}">0.00</span>
                </td>
                <td class="text-center align-middle">
                    <button type="button"
                            class="btn btn-sm btn-outline-danger"
                            onclick="eliminarFila(${indice})">✕</button>
                </td>
            </tr>`;
        }

        // Agrega una nueva fila al detalle
        function agregarFila() {
            const tbody = document.getElementById('cuerpoDetalle');
            tbody.insertAdjacentHTML('beforeend', construirFila(indiceFila));
            indiceFila++;
        }

        // Elimina una fila — no permite dejar la tabla vacía
        function eliminarFila(indice) {
            const filas = document.querySelectorAll('#cuerpoDetalle tr');
            if (filas.length <= 1) {
                alert('Debe haber al menos un producto en el detalle.');
                return;
            }
            document.getElementById(`fila-${indice}`).remove();
            calcularTotal();
        }

        // Calcula el subtotal de una fila
        function calcularSubtotal(indice) {
            const cantidad = parseFloat(
                document.querySelector(`[name="Detalles[${indice}].Cantidad"]`)?.value
            ) || 0;
            const precio = parseFloat(
                document.querySelector(`[name="Detalles[${indice}].PrecioUnitario"]`)?.value
            ) || 0;

            const subtotal = cantidad * precio;
            document.getElementById(`subtotal-${indice}`).textContent =
                subtotal.toFixed(2);

            calcularTotal();
        }

        // Suma todos los subtotales y actualiza el total general
        function calcularTotal() {
            const spans = document.querySelectorAll('[id^="subtotal-"]');
            let total = 0;
            spans.forEach(s => total += parseFloat(s.textContent) || 0);
            document.getElementById('totalGeneral').textContent =
                total.toFixed(2);
        }

        // Arrancamos con una fila vacía al cargar la página
        agregarFila();
    </script>
}

