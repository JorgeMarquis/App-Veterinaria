@model Veterinaria.Web.ViewModels.CategoriaProductos.CategoriaProductoViewModel
@{
    bool isCreate = Model.IdCategoria == 0;
    ViewBag.Title = isCreate ? "Crear Categoría de Producto" : "Editar Categoría de Producto";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-5">
                <h4 class="fw-bold mb-4 text-dark">
                    <i class="bi @(Model.IdCategoria == 0 ? "bi-plus-circle" : "bi-pencil-square") text-primary me-2"></i>
                    @ViewBag.Title
                </h4>

                <form asp-action="@(Model.IdCategoria == 0 ? "Create" : "Edit")" novalidate>
                    @if (!isCreate)
                    {
                        <input type="hidden" asp-for="IdCategoria" />
                    }
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <div class="form-floating">
                                <label asp-for="Nombre" class="form-label">Nombre de la Categoría <span class="text-danger">*</span></label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre de la categoría" required />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" placeholder="Ingrese una descripción opcional para la categoría"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        @if (!isCreate)
                        {
                            <div class="col-md-12 mt-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="Activo" id="activoCheck" />
                                    <label class="form-check-label fw-bold" for="activoCheck">
                                        Categoria de Productos Activo
                                    </label>
                                </div>
                            </div>
                        }

                        <div>
                            <a asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                @(isCreate ? "Crear Categoría" : "Guardar Cambios")
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
